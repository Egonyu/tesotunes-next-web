# =============================================================================
# TesoTunes Next.js Frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_NAME=TesoTunes
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Laravel API ---
# MUST include the /api suffix.  Local: http://tesotunes-api.test/api
# Production: https://api.tesotunes.com/api
NEXT_PUBLIC_API_URL=http://tesotunes-api.test/api

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=           # REQUIRED — generate with: openssl rand -base64 32
# Set to "true" on Vercel to enable debug logging for auth troubleshooting
# NEXTAUTH_DEBUG=true

# --- OAuth Providers (for NextAuth social sign-in) ---
# Comma-separated social providers to expose in web UI + NextAuth.
# Example: google OR google,facebook
AUTH_SOCIAL_PROVIDERS=google
# Client-visible fallback (used by client pages if server-only var is missing)
NEXT_PUBLIC_AUTH_SOCIAL_PROVIDERS=google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- reCAPTCHA Enterprise ---
# Site key from Google reCAPTCHA Enterprise console (public — safe to expose)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LcmpOssAAAAAIWXAIy5tkDUQHalpMPbsT1XQt2z

# --- Pusher / Laravel Echo (realtime) ---
# Production default: use managed Pusher
NEXT_PUBLIC_PUSHER_APP_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=mt1

# Optional local/self-hosted Reverb mode.
# Leave unset in production when using Pusher.
NEXT_PUBLIC_REVERB_APP_KEY=
NEXT_PUBLIC_REVERB_HOST=
NEXT_PUBLIC_REVERB_PORT=8080
NEXT_PUBLIC_REVERB_SCHEME=http

# --- Feature Flags ---
NEXT_PUBLIC_PODCAST_ENABLED=true
NEXT_PUBLIC_STORE_ENABLED=false
NEXT_PUBLIC_ENABLE_ADS=false
NEXT_PUBLIC_ENABLE_FEATURED=true
NEXT_PUBLIC_ENABLE_ADMIN_REPORTS=false

# --- Database (only if Next.js needs direct DB access) ---
# DATABASE_URL=mysql://root:password@localhost:3306/tesotunes_dev

