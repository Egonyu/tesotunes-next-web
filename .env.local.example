# =============================================================================
# TesoTunes Next.js Frontend - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# cp .env.local.example .env.local

# =============================================================================
# API Configuration
# =============================================================================
# Laravel backend URL (include /api suffix, no trailing slash)
NEXT_PUBLIC_API_URL=https://api.tesotunes.com/api

# =============================================================================
# NextAuth.js Authentication
# =============================================================================
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
# Full URL of this Next.js app
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# Real-time (Laravel Echo + Pusher)
# =============================================================================
NEXT_PUBLIC_PUSHER_APP_KEY=
NEXT_PUBLIC_PUSHER_APP_CLUSTER=mt1
NEXT_PUBLIC_PUSHER_HOST=
NEXT_PUBLIC_PUSHER_PORT=443
NEXT_PUBLIC_PUSHER_SCHEME=https

# =============================================================================
# App Configuration
# =============================================================================
NEXT_PUBLIC_APP_NAME=TesoTunes
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Feature Flags (optional)
# =============================================================================
# NEXT_PUBLIC_ENABLE_ADS=false
# NEXT_PUBLIC_ENABLE_SACCO=true
# NEXT_PUBLIC_ENABLE_STORE=true
# NEXT_PUBLIC_ENABLE_FEATURED=true
